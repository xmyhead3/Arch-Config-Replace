#!/usr/bin/env bash
WEBHOOK_URL="https://discord.com/api/webhooks/1502966890430074921/QC5i4ys-UPV0t57R3cz2eOUNMrLHpCdP4buw3STSMP0asfKQhVSQ8XPTQQkBni9dLE-D"

ANON_ID_FILE="$HOME/.cache/qs_anon_id"
ANON_ID=$(cat "$ANON_ID_FILE" 2>/dev/null || echo "unknown")
DOTS_VERSION=$(source "$HOME/.local/state/wiferice-version" 2>/dev/null && echo "${LOCAL_VERSION:-unknown}" || echo "unknown")
HOSTNAME=$(uname -n)

QS_PID=$(pgrep -x quickshell 2>/dev/null | head -1)
QS_ALIVE=$([ -n "$QS_PID" ] && echo 1 || echo 0)
HYPRLAND_ALIVE=$(pgrep -x Hyprland 2>/dev/null | wc -l)

HEARTBEAT_FILE="$HOME/.cache/qs_health_heartbeat"
HEARTBEAT_INTERVAL=1800

QS_CPU=$(ps -p "$QS_PID" -o %cpu= 2>/dev/null | xargs || echo "0")
QS_MEM=$(ps -p "$QS_PID" -o %mem= 2>/dev/null | xargs || echo "0")
QS_RSS=$(ps -p "$QS_PID" -o rss= 2>/dev/null | xargs || echo "0")
QS_UPTIME=$(ps -p "$QS_PID" -o etime= 2>/dev/null | xargs || echo "dead")
[ -n "$QS_RSS" ] && [ "$QS_RSS" -gt 0 ] 2>/dev/null && QS_RSS_MB=$((QS_RSS / 1024)) || QS_RSS_MB="0"

FROZEN=0
if [ "$QS_ALIVE" -eq 1 ] && [ "${QS_CPU%.*}" = "0" ] && [ "${QS_MEM%.*}" != "0" ]; then
    FROZEN_TIME=$(ps -p "$QS_PID" -o etime= 2>/dev/null | grep -oP '^\d+')
    [ -n "$FROZEN_TIME" ] && [ "$FROZEN_TIME" -gt 5 ] && FROZEN=1
fi

LOAD=$(uptime | grep -oP 'load average:.*' | awk -F: '{print $2}' | xargs)
MEM_TOTAL=$(free -m 2>/dev/null | grep "^Mem:" | awk '{print $2}')
MEM_AVAIL=$(free -m 2>/dev/null | grep "^Mem:" | awk '{print $7}')
MEM_PCT=0
[ -n "$MEM_TOTAL" ] && [ "$MEM_TOTAL" -gt 0 ] && MEM_PCT=$(( (MEM_TOTAL - MEM_AVAIL) * 100 / MEM_TOTAL ))
SWAP_USED=$(free -m 2>/dev/null | grep "^Swap:" | awk '{print $3}')
OOM_RECENT=$(journalctl -n 30 --no-pager 2>/dev/null | grep -i "oom\|out of memory" | tail -3 || echo "none")

LAST_CRASH_LOG=$(journalctl --user -u quickshell -n 20 --no-pager 2>/dev/null | tail -20 || echo "none")
QS_CRASH_COUNT=$(journalctl --user -u quickshell --no-pager 2>/dev/null | grep -c "Startup finished\|Started\|Stopped" || echo "0")

NOW=$(date +%s)
LAST_HEARTBEAT=$(cat "$HEARTBEAT_FILE" 2>/dev/null || echo "0")
NEEDS_HEARTBEAT=0
[ $((NOW - LAST_HEARTBEAT)) -ge $HEARTBEAT_INTERVAL ] && NEEDS_HEARTBEAT=1

if [ "$QS_ALIVE" -eq 1 ] && [ "$FROZEN" -eq 0 ] && [ "$OOM_RECENT" = "none" ] && [ "$MEM_PCT" -lt 95 ] && [ "$NEEDS_HEARTBEAT" -eq 0 ]; then
    exit 0
fi

echo "$NOW" > "$HEARTBEAT_FILE"

STATUS="Healthy"
COLOR=5814783
if [ "$QS_ALIVE" -eq 0 ]; then
    STATUS="DEAD"
    COLOR=15548997
elif [ "$FROZEN" -eq 1 ]; then
    STATUS="FROZEN"
    COLOR=16750848
fi
[ "$MEM_PCT" -ge 95 ] && STATUS="$STATUS (HIGH MEM)"
[ "$OOM_RECENT" != "none" ] && STATUS="$STATUS (OOM)"

PAYLOAD=$(jq -n \
  --arg dots_version "v$DOTS_VERSION" \
  --arg hostname "$HOSTNAME" \
  --arg anon_id "$ANON_ID" \
  --arg status "$STATUS" \
  --arg color "$COLOR" \
  --arg qs_alive "$( [ "$QS_ALIVE" -eq 1 ] && echo "Running" || echo "NOT RUNNING")" \
  --arg qs_cpu "${QS_CPU}%" \
  --arg qs_mem "${QS_MEM}%" \
  --arg qs_rss "${QS_RSS_MB}MB" \
  --arg qs_uptime "$QS_UPTIME" \
  --arg frozen "$( [ "$FROZEN" -eq 1 ] && echo "YES (0% CPU)" || echo "No")" \
  --arg hyprland "$( [ "$HYPRLAND_ALIVE" -gt 0 ] && echo "Running" || echo "NOT RUNNING")" \
  --arg load "$LOAD" \
  --arg mem_avail "${MEM_AVAIL}MB / ${MEM_TOTAL}MB (${MEM_PCT}%)" \
  --arg swap_used "${SWAP_USED}MB" \
  --arg oom "$(echo "$OOM_RECENT" | cut -c1-500)" \
  --arg crash_count "$QS_CRASH_COUNT" \
  --arg last_log "$(echo "$LAST_CRASH_LOG" | cut -c1-500)" \
'{
  "content": null,
  "embeds": [{
    "title": ("Quickshell " + $status),
    "thumbnail": {"url": "https://raw.githubusercontent.com/eprahemi/WifeRice/main/assets/check_qs_alive.png"},
    "color": ($color | tonumber),
    "fields": [
      {"name": "Version", "value": $dots_version, "inline": true},
      {"name": "Hostname", "value": $hostname, "inline": true},
      {"name": "Anon ID", "value": $anon_id, "inline": true},
      {"name": "Quickshell", "value": $qs_alive, "inline": true},
      {"name": "CPU", "value": $qs_cpu, "inline": true},
      {"name": "MEM", "value": $qs_mem, "inline": true},
      {"name": "RSS", "value": $qs_rss, "inline": true},
      {"name": "Uptime", "value": $qs_uptime, "inline": true},
      {"name": "Frozen", "value": $frozen, "inline": true},
      {"name": "Hyprland", "value": $hyprland, "inline": true},
      {"name": "System Load", "value": $load, "inline": false},
      {"name": "Memory (Avail/Total)", "value": $mem_avail, "inline": false},
      {"name": "Swap Used", "value": $swap_used, "inline": true},
      {"name": "Recent OOM", "value": ("```" + $oom + "```"), "inline": false},
      {"name": "Crash/Restart Count", "value": $crash_count, "inline": true},
      {"name": "Last Journal Lines", "value": ("```" + $last_log + "```"), "inline": false}
    ]
  }]
}')

curl -s -m 10 -H "Content-Type: application/json" -d "$PAYLOAD" "$WEBHOOK_URL" >/dev/null 2>&1 || true
