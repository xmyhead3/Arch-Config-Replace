#!/usr/bin/env bash
WEBHOOK_URL="https://discord.com/api/webhooks/1502967148576768041/lBGJROT373nQe7lSqn1tVklr36D6FR7U9tyWoonVxS-pf0S0-Z6SFtHl5r5DCHttf_50"

ANON_ID_FILE="$HOME/.cache/qs_anon_id"
ANON_ID=$(cat "$ANON_ID_FILE" 2>/dev/null || echo "unknown")
HOSTNAME=$(uname -n)

LOCAL_VERSION=$(source "$HOME/.local/state/wiferice-version" 2>/dev/null && echo "${LOCAL_VERSION:-unknown}" || echo "unknown")
REMOTE_VERSION=$(curl -fsSL "https://raw.githubusercontent.com/eprahemi/WifeRice/main/install.sh" 2>/dev/null | grep "DOTS_VERSION=" | head -1 | cut -d'"' -f2 || echo "unknown")

if [ "$REMOTE_VERSION" = "unknown" ] || [ "$LOCAL_VERSION" = "$REMOTE_VERSION" ]; then
    exit 0
fi

STALE_DAYS=$(( ($(date +%s) - $(stat -c %Y "$HOME/.local/state/wiferice-version" 2>/dev/null || echo "0")) / 86400 ))

PAYLOAD=$(jq -n \
  --arg hostname "$HOSTNAME" \
  --arg anon_id "$ANON_ID" \
  --arg local_version "v$LOCAL_VERSION" \
  --arg remote_version "v$REMOTE_VERSION" \
  --arg stale_days "$STALE_DAYS" \
'{
  "content": null,
  "embeds": [{
    "title": "Version Staleness",
    "thumbnail": {"url": "https://raw.githubusercontent.com/eprahemi/WifeRice/main/assets/check_version.png"},
    "color": 16750848,
    "fields": [
      {"name": "Hostname", "value": $hostname, "inline": true},
      {"name": "Anon ID", "value": $anon_id, "inline": true},
      {"name": "Local Version", "value": $local_version, "inline": true},
      {"name": "Latest", "value": $remote_version, "inline": true},
      {"name": "Days Behind", "value": $stale_days, "inline": true},
      {"name": "Needs Update", "value": "YES", "inline": true}
    ]
  }]
}')

curl -s -m 10 -H "Content-Type: application/json" -d "$PAYLOAD" "$WEBHOOK_URL" >/dev/null 2>&1 || true
