/* SWAYNC STYLE - ROUNDED, ELEGANT & DYNAMIC
   Powered by Matugen
*/

* {
  all: unset;
  font-size: 14px;
  font-family: "Ubuntu Nerd Font", sans-serif;
  transition: all 250ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* --- SLIDERS (Volume / Backlight) --- */
trough highlight {
  background: {{colors.on_surface.default.hex}};
  border-radius: 24px;
}

scale {
  margin: 0 8px;
}

scale trough {
  margin: 0rem 1rem;
  min-height: 14px; 
  min-width: 70px;
  border-radius: 24px; 
  background-color: {{colors.surface_container_high.default.hex}};
  box-shadow: inset 0 2px 4px rgba(0,0,0,0.25); 
}

trough slider {
  margin: -10px;
  min-width: 24px;
  min-height: 24px;
  border-radius: 50%; 
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
  background-color: {{colors.primary.default.hex}};
}

trough slider:hover {
  transform: scale(1.15); 
  box-shadow: 0 0 4px rgba(0, 0, 0, 0.5), 0 0 12px {{colors.primary.default.hex}};
}

/* --- NOTIFICATIONS --- */
.notification-background {
  box-shadow: 0 6px 16px 0 rgba(0, 0, 0, 0.4), inset 0 0 0 1px {{colors.outline_variant.default.hex}};
  border-radius: 28px; 
  margin: 12px;
  background: {{colors.surface_container_low.default.hex}};
  color: {{colors.on_surface.default.hex}};
  padding: 6px;
}

.notification-background .notification {
  padding: 12px;
  border-radius: 22px;
}

.notification-background .notification.critical {
  box-shadow: inset 0 0 10px 0 {{colors.error.default.hex}};
  border: 1px solid {{colors.error.default.hex}};
}

.notification .notification-content {
  margin: 8px;
}

.notification .notification-content overlay {
  margin: 4px;
}

.notification-content .summary {
  color: {{colors.on_surface.default.hex}};
  font-weight: bold;
  font-size: 1.15em;
}

.notification-content .time {
  color: {{colors.on_surface_variant.default.hex}};
  font-size: 0.9em;
  margin-right: 5px;
}

.notification-content .body {
  color: {{colors.on_surface_variant.default.hex}};
  margin-top: 6px;
}

.notification > *:last-child > * {
  min-height: 3.4em;
}

/* Close Button */
.notification-background .close-button {
  margin: 8px;
  padding: 6px;
  border-radius: 50%; 
  color: {{colors.surface.default.hex}};
  background-color: {{colors.error.default.hex}};
  min-width: 24px;
  min-height: 24px;
  box-shadow: 0 4px 8px rgba(0,0,0,0.25);
}

.notification-background .close-button:hover {
  background-color: {{colors.error_container.default.hex}};
  transform: rotate(90deg) scale(1.1); 
}

.notification-background .close-button:active {
  background-color: {{colors.error.default.hex}};
  transform: rotate(90deg) scale(0.9);
}

/* Actions */
.notification .notification-action {
  border-radius: 16px;
  color: {{colors.on_surface.default.hex}};
  box-shadow: inset 0 0 0 1px {{colors.outline_variant.default.hex}};
  margin: 6px;
  padding: 6px 12px;
  font-size: 1rem;
  background-color: {{colors.surface_container_high.default.hex}};
}

.notification .notification-action:hover {
  background-color: {{colors.outline_variant.default.hex}};
  color: {{colors.primary.default.hex}};
}

.notification .notification-action:active {
  background-color: {{colors.surface_variant.default.hex}};
}

/* Progress Bars */
.notification.critical progress {
  background-color: {{colors.error.default.hex}};
}

.notification.low progress,
.notification.normal progress {
  background-color: {{colors.primary.default.hex}};
}

.notification progress,
.notification trough,
.notification progressbar {
  border-radius: 24px;
  min-height: 8px;
}

/* --- CONTROL CENTER --- */
.control-center {
  box-shadow: 0 10px 30px 0 rgba(0, 0, 0, 0.7), inset 0 0 0 1px {{colors.surface_container_high.default.hex}};
  border-radius: 36px; 
  background-color: {{colors.surface.default.hex}};
  color: {{colors.on_surface.default.hex}};
  padding: 24px;
  margin: 12px;
}

.control-center .notification-background {
  border-radius: 24px;
  box-shadow: inset 0 0 0 1px {{colors.outline_variant.default.hex}};
  margin: 8px 0;
}

.control-center .notification-background .notification {
  border-radius: 18px;
}

.control-center .notification-background .notification.low {
  opacity: 0.8;
}

/* Widgets Title */
.control-center .widget-title > label {
  color: {{colors.on_surface.default.hex}};
  font-size: 1.5em;
  font-weight: 800;
  margin-bottom: 12px;
}

.control-center .widget-title button {
  border-radius: 16px;
  color: {{colors.on_surface.default.hex}};
  background-color: {{colors.surface_container_high.default.hex}};
  box-shadow: inset 0 0 0 1px {{colors.outline_variant.default.hex}};
  padding: 8px 16px;
  font-weight: 700;
}

.control-center .widget-title button:hover {
  background-color: {{colors.outline_variant.default.hex}};
  color: {{colors.secondary.default.hex}};
}

.control-center .widget-title button:active {
  background-color: {{colors.surface_variant.default.hex}};
}

.control-center .notification-group {
  margin-top: 12px;
}

.control-center .notification-group:focus .notification-background {
  background-color: {{colors.surface_container_high.default.hex}};
}

/* Scrollbar */
scrollbar slider {
  min-width: 8px;
  margin: 0px 6px;
  background: {{colors.surface_variant.default.hex}};
  border-radius: 24px;
  opacity: 0.8;
}

scrollbar trough {
  margin: 0;
}

/* --- DND TOGGLE --- */
.widget-dnd {
  margin-top: 12px;
  border-radius: 20px;
  background: {{colors.surface_container_high.default.hex}}; 
  padding: 8px 18px;
}

.widget-dnd > switch {
  font-size: initial;
  border-radius: 24px;
  background: {{colors.outline_variant.default.hex}};
  box-shadow: inset 0 0 6px rgba(0,0,0,0.4);
}

.widget-dnd > switch:checked {
  background: {{colors.primary.default.hex}};
}

.widget-dnd > switch slider {
  background: {{colors.on_surface.default.hex}};
  border-radius: 50%;
  margin: 3px;
}

/* --- MPRIS (Media) --- */
.widget-mpris-player {
  background: {{colors.surface_container_high.default.hex}};
  border-radius: 28px;
  color: {{colors.on_surface.default.hex}};
  padding: 12px;
  margin: 12px 0;
  box-shadow: 0 6px 12px rgba(0,0,0,0.25);
}

.widget-mpris-album-art {
  border-radius: 20px;
  margin-right: 18px;
}

.widget-mpris-title {
  font-size: 1.3rem;
  font-weight: 800;
  color: {{colors.on_surface.default.hex}};
}

.widget-mpris-subtitle {
  font-size: 1rem;
  color: {{colors.on_surface_variant.default.hex}};
}

.widget-mpris button {
  border-radius: 50%; 
  color: {{colors.on_surface.default.hex}};
  margin: 0 6px;
  padding: 10px;
}

.widget-mpris button:hover {
  background-color: {{colors.outline_variant.default.hex}};
  color: {{colors.primary.default.hex}};
}

/* --- BUTTON GRID --- */
.widget-buttons-grid {
  padding-top: 1.2rem;
}

.widget-buttons-grid > flowbox > flowboxchild > button {
  background: {{colors.surface_container_high.default.hex}};
  border-radius: 20px;
  margin: 6px;
  padding: 12px;
  box-shadow: 0 4px 8px rgba(0,0,0,0.2);
}

.widget-buttons-grid > flowbox > flowboxchild > button:hover {
  background: {{colors.outline_variant.default.hex}};
  transform: translateY(-2px);
}

.widget-buttons-grid > flowbox > flowboxchild > button label {
  font-size: 1.8rem; 
}

/* --- VOLUME & BACKLIGHT --- */
.widget-volume, .widget-backlight {
  background: {{colors.surface_container_low.default.hex}}; 
  border-radius: 24px;
  margin: 6px 0;
  padding: 8px;
}

.widget-volume label {
  color: {{colors.tertiary.default.hex}};
  font-size: 1.5rem;
  padding-left: 12px;
}

.widget-volume trough highlight {
  background: {{colors.tertiary.default.hex}};
}

.widget-backlight trough highlight {
  background: {{colors.secondary.default.hex}};
}

.widget-backlight label {
  font-size: 1.5rem;
  color: {{colors.secondary.default.hex}};
  padding-left: 12px;
}
